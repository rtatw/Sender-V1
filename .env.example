# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_ID=YOUR_TELEGRAM_USER_ID_HERE
# Получить ID можно через бота @userinfobot или @getmyid_bot

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///bot_data.db

# ─── Encryption (ОБЯЗАТЕЛЬНО) ─────────────────────────────────────────────────
# Сгенерировать ключ:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ВНИМАНИЕ: Потеря этого ключа = потеря всех зашифрованных паролей в БД!
ENCRYPTION_KEY=your_fernet_key_here

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=3

# ─── FSM ──────────────────────────────────────────────────────────────────────
# FSM_TIMEOUT_SECONDS=600
# REDIS_URL=redis://localhost:6379/0
# Если REDIS_URL не задан — используется MemoryStorage

# ─── GOO CORE API (для кнопки Card) ──────────────────────────────────────────
# Team Key из кабинета goo.network:
GOO_TEAM_KEY=your_goo_team_key_here

# ─── Deploy (только для deploy.py, не нужен боту) ────────────────────────────
DEPLOY_HOST=YOUR_SERVER_IP
DEPLOY_USER=root
DEPLOY_PASSWORD=YOUR_SSH_PASSWORD
# Опционально — если отличаются от дефолтных:
# DEPLOY_LOCAL_DIR=C:\Users\admin\Desktop\premir\Bot
# DEPLOY_REMOTE_DIR=/root/bot
